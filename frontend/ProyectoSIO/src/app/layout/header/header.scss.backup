// Apple-style Navigation Bar
.header {
  position: sticky;
  top: 0;
  z-index: 1000;
  background: rgba(251, 251, 253, 0.8);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.navbar {
  height: 44px;
  
  .nav-content {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    position: relative;
    
    @media (max-width: 1068px) {
      max-width: 692px;
    }
    
    @media (max-width: 734px) {
      padding: 0 16px;
    }
  }
}

// Brand Logo
.nav-brand {
  text-decoration: none;
  color: #1d1d1f;
  transition: opacity 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  
  &:hover {
    opacity: 0.6;
  }
  
  .brand-logo {
    font-size: 21px;
    font-weight: 600;
    letter-spacing: 0.5px;
    line-height: 1;
    
    @media (max-width: 734px) {
      font-size: 18px;
    }
  }
}

// Navigation Links
.nav-list {
  display: flex;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 32px;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  
  @media (max-width: 833px) {
    display: none;
  }
  
  .nav-item {
    .nav-link {
      color: #1d1d1f;
      text-decoration: none;
      font-size: 12px;
      font-weight: 400;
      letter-spacing: -0.01em;
      line-height: 1;
      transition: opacity 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
      opacity: 0.8;
      
      &:hover {
        opacity: 1;
      }
      
      &.active {
        opacity: 1;
        font-weight: 500;
      }
    }
  }
}

// Action Icons
.nav-actions {
  display: flex;
  align-items: center;
  gap: 18px;
  
  @media (max-width: 734px) {
    gap: 12px;
  }
  
  .nav-icon-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: #1d1d1f;
    cursor: pointer;
    border-radius: 50%;
    transition: all 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
    opacity: 0.8;
    position: relative;
    
    &:hover {
      opacity: 1;
      background: rgba(0, 0, 0, 0.04);
    }
    
    svg {
      width: 18px;
      height: 18px;
    }
    
    &.mobile-menu-btn {
      display: none;
      
      @media (max-width: 833px) {
        display: flex;
      }
    }
    
    @media (max-width: 734px) {
      width: 32px;
      height: 32px;
      
      svg {
        width: 16px;
        height: 16px;
      }
    }
  }
  
  .cart-btn {
    .cart-badge {
      position: absolute;
      top: 6px;
      right: 6px;
      background: #0071e3;
      color: white;
      font-size: 9px;
      font-weight: 600;
      min-width: 16px;
      height: 16px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 4px;
    }
  }
}

// Search Overlay
.search-overlay {
  position: fixed;
  top: 44px;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.48);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  z-index: 999;
  animation: fadeIn 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  
  .search-container {
    max-width: 680px;
    margin: 0 auto;
    padding: 32px 24px;
    
    @media (max-width: 734px) {
      padding: 20px 16px;
    }
  }
  
  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 0 16px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    transition: all 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
    
    &:focus-within {
      background: rgba(255, 255, 255, 0.18);
      border-color: rgba(255, 255, 255, 0.28);
    }
    
    svg {
      color: rgba(255, 255, 255, 0.6);
      flex-shrink: 0;
    }
    
    .search-input {
      flex: 1;
      background: transparent;
      border: none;
      color: white;
      font-size: 17px;
      padding: 0 12px;
      outline: none;
      font-weight: 400;
      
      &::placeholder {
        color: rgba(255, 255, 255, 0.5);
      }
    }
    
    .search-close {
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.12);
      border: none;
      border-radius: 50%;
      color: rgba(255, 255, 255, 0.7);
      cursor: pointer;
      transition: all 0.2s;
      
      &:hover {
        background: rgba(255, 255, 255, 0.18);
        color: white;
      }
    }
  }
  
  .search-results {
    margin-top: 16px;
    background: rgba(42, 42, 46, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    
    .search-result-item {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding: 12px 16px;
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      color: white;
      text-align: left;
      cursor: pointer;
      transition: background 0.2s;
      
      &:last-child {
        border-bottom: none;
      }
      
      &:hover {
        background: rgba(255, 255, 255, 0.08);
      }
      
      .result-title {
        font-size: 15px;
        font-weight: 500;
        margin-bottom: 2px;
      }
      
      .result-description {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.6);
      }
    }
  }
}

// Mobile Menu
.mobile-menu {
  position: fixed;
  top: 44px;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.48);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  z-index: 999;
  animation: fadeIn 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  
  .mobile-menu-content {
    background: rgba(251, 251, 253, 0.92);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    padding: 12px 0;
    
    .mobile-nav-list {
      list-style: none;
      margin: 0;
      padding: 0;
      
      .mobile-nav-item {
        .mobile-nav-link {
          display: block;
          padding: 14px 24px;
          color: #1d1d1f;
          text-decoration: none;
          font-size: 17px;
          font-weight: 400;
          letter-spacing: -0.022em;
          transition: background 0.2s;
          border-bottom: 1px solid rgba(0, 0, 0, 0.04);
          
          &:hover {
            background: rgba(0, 0, 0, 0.02);
          }
        }
      }
    }
  }
}

// Animations
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
      }
    }
  }
}

.navbar-actions {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  
  @media (max-width: 768px) {
    gap: 0.5rem;
  }
  
  .icon-btn {
    background: rgba(0, 0, 0, 0);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    padding: 0.5rem;
    color: #86868b;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    
    &:hover {
      background: rgba(0, 0, 0, 0.05);
      color: #1d1d1f;
    }
    
    &:active {
      transform: scale(0.95);
    }
    
    svg {
      width: 20px;
      height: 20px;
      
      @media (max-width: 768px) {
        width: 22px;
        height: 22px;
      }
    }
  }
  
  .desktop-icon {
    @media (max-width: 968px) {
      display: none;
    }
  }
  
  .cart-btn {
    position: relative;
    
    .cart-badge {
      position: absolute;
      top: -2px;
      right: -2px;
      background: linear-gradient(135deg, #ff3b30 0%, #ff2d55 100%);
      color: white;
      border-radius: 10px;
      min-width: 18px;
      height: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.65rem;
      font-weight: 600;
      padding: 0 5px;
      box-shadow: 0 2px 8px rgba(255, 59, 48, 0.3);
      border: 2px solid rgba(255, 255, 255, 0.9);
    }
  }
}

// Search Container
.search-container {
  position: relative;
  display: flex;
  align-items: center;
  
  .search-btn {
    z-index: 2;
  }
  
  .search-input-wrapper {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 0;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    
    &.expanded {
      width: 400px;
      opacity: 1;
      visibility: visible;
      
      @media (max-width: 968px) {
        width: 320px;
      }
      
      @media (max-width: 768px) {
        width: 280px;
      }
    }
    
    .search-input {
      width: 100%;
      padding: 0.75rem 1rem 0.75rem 3rem;
      border: 1px solid rgba(0, 0, 0, 0.12);
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      font-size: 0.9375rem;
      color: #1d1d1f;
      outline: none;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      
      &::placeholder {
        color: #86868b;
      }
      
      &:focus {
        border-color: #1d1d1f;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
      }
    }
    
    .search-dropdown {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(30px) saturate(180%);
      -webkit-backdrop-filter: blur(30px) saturate(180%);
      border-radius: 12px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
      border: 1px solid rgba(0, 0, 0, 0.08);
      overflow: hidden;
      animation: slideDown 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 1003;
      max-height: 480px;
      display: flex;
      flex-direction: column;
      
      @media (max-width: 768px) {
        max-height: 360px;
      }
    }
    
    .search-results {
      overflow-y: auto;
      
      &::-webkit-scrollbar {
        width: 6px;
      }
      
      &::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.02);
      }
      
      &::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, 0.15);
        border-radius: 3px;
        
        &:hover {
          background: rgba(0, 0, 0, 0.25);
        }
      }
    }
    
    .search-result-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      border: none;
      background: transparent;
      width: 100%;
      text-align: left;
      cursor: pointer;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      
      &:last-child {
        border-bottom: none;
      }
      
      &:hover {
        background: rgba(0, 0, 0, 0.04);
        
        .result-arrow {
          transform: translateX(4px);
          opacity: 1;
        }
      }
      
      &:active {
        background: rgba(0, 0, 0, 0.08);
      }
      
      .result-icon {
        min-width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.05);
        border-radius: 8px;
        color: #1d1d1f;
        
        svg {
          width: 16px;
          height: 16px;
        }
      }
      
      .result-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        min-width: 0;
        
        .result-title {
          font-weight: 600;
          color: #1d1d1f;
          font-size: 0.9375rem;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
        }
        
        .result-description {
          font-size: 0.8125rem;
          color: #86868b;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
        }
        
        .result-section {
          font-size: 0.75rem;
          color: #86868b;
          font-weight: 500;
          margin-top: 0.125rem;
        }
      }
      
      .result-arrow {
        min-width: 16px;
        height: 16px;
        color: #86868b;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        opacity: 0.5;
      }
    }
    
    .search-footer {
      padding: 0.75rem 1.25rem;
      background: rgba(0, 0, 0, 0.02);
      border-top: 1px solid rgba(0, 0, 0, 0.05);
      
      .search-hint {
        font-size: 0.8125rem;
        color: #86868b;
        font-weight: 500;
      }
    }
  }
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

// Hamburger Button
.hamburger-btn {
  display: none;
  background: rgba(0, 0, 0, 0);
  border: none;
  border-radius: 8px;
  cursor: pointer;
  padding: 0.5rem;
  color: #1d1d1f;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  
  &:hover {
    background: rgba(0, 0, 0, 0.05);
  }
  
  &:active {
    transform: scale(0.95);
  }
  
  @media (max-width: 968px) {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  svg {
    width: 24px;
    height: 24px;
  }
}

.mobile-only {
  display: none;
  
  @media (max-width: 968px) {
    display: flex;
  }
}

// Mobile Menu
.mobile-menu {
  position: fixed;
  top: 0;
  right: -100%;
  width: 75%;
  max-width: 320px;
  height: 100vh;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  box-shadow: -4px 0 24px rgba(0, 0, 0, 0.12);
  border-left: 1px solid rgba(0, 0, 0, 0.08);
  transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  overflow-y: auto;
  z-index: 1001;
  padding-top: 129px;
  
  @media (max-width: 768px) {
    padding-top: 109px;
  }
  
  &.open {
    right: 0;
  }
  
  @media (min-width: 969px) {
    display: none;
  }
}

.mobile-menu-list {
  list-style: none;
  margin: 0;
  padding: 2rem 0;
  
  .mobile-nav-item {
    .mobile-nav-link {
      display: block;
      padding: 1.25rem 2rem;
      color: #1d1d1f;
      text-decoration: none;
      font-weight: 500;
      font-size: 1.05rem;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      width: 100%;
      text-align: left;
      border: none;
      background: none;
      cursor: pointer;
      letter-spacing: -0.01em;
      
      &::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 3px;
        height: 0;
        background-color: #1d1d1f;
        border-radius: 0 2px 2px 0;
        transition: height 0.2s ease;
      }
      
      &:hover {
        background: rgba(0, 0, 0, 0.04);
        padding-left: 2.5rem;
        
        &::before {
          height: 60%;
        }
      }
      
      &:active {
        background: rgba(0, 0, 0, 0.08);
      }
      
      &.logout-btn {
        color: #ff3b30;
        
        &::before {
          background-color: #ff3b30;
        }
      }
    }
  }
}

// Overlay
.mobile-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1), 
              visibility 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1000;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  
  &.visible {
    opacity: 1;
    visibility: visible;
  }
  
  @media (min-width: 969px) {
    display: none;
  }
}
