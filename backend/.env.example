# ============================================
# CONFIGURACIÓN DEL BACKEND
# ============================================

# Puerto del servidor
PORT=3000

# Configuración de CORS
CORS_ORIGIN=http://localhost:4200

# Configuración JWT
JWT_SECRET=tu_clave_secreta_aqui_cambiar_en_produccion

# Entorno
NODE_ENV=development

# ============================================
# BASE DE DATOS MySQL
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sistema_gestion

# ============================================
# CONFIGURACIÓN DEL CHATBOT IA
# ============================================
# Elige UNO de los siguientes proveedores gratuitos

# --------------------------------------------
# Opción 1: DeepSeek (RECOMENDADO) ⭐
# - Completamente gratuito
# - Sin límites de uso
# - Excelente calidad
# Obtén tu API key en: https://platform.deepseek.com/
# --------------------------------------------
AI_PROVIDER=deepseek
AI_API_KEY=tu_deepseek_api_key_aqui

# --------------------------------------------
# Opción 2: Groq (MÁS RÁPIDO) 🚀
# - Completamente gratuito
# - Ultra rápido (< 1 segundo)
# - Llama 3.3 70B
# Obtén tu API key en: https://console.groq.com/
# --------------------------------------------
# AI_PROVIDER=groq
# AI_API_KEY=tu_groq_api_key_aqui

# --------------------------------------------
# Opción 3: Hugging Face
# - Gratuito
# - Mixtral 8x7B
# Obtén tu token en: https://huggingface.co/settings/tokens
# --------------------------------------------
# AI_PROVIDER=huggingface
# AI_API_KEY=tu_huggingface_token_aqui

# --------------------------------------------
# Opción 4: Sin API (Modo Fallback)
# - Descomenta las siguientes líneas para usar
#   respuestas predefinidas sin necesidad de API
# --------------------------------------------
# AI_PROVIDER=fallback
# AI_API_KEY=

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. Copia este archivo a .env y configura tus valores reales
# 2. NUNCA subas el archivo .env a Git (está en .gitignore)
# 3. Reinicia el servidor después de modificar .env
# 4. Para verificar tu configuración ejecuta:
#    node -p "require('dotenv').config(); console.log({provider: process.env.AI_PROVIDER, hasKey: !!process.env.AI_API_KEY})"
